VS_AGENT_DATA_DIR=data

# OpenAI-compatible settings. OPENAI_API_KEY can also be set as a system/user
# environment variable, so this file does not need to contain the key.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen-plus
OPENAI_EMBEDDING_MODEL=text-embedding-v4
OPENAI_TIMEOUT_SECONDS=180
OPENAI_MAX_RETRIES=2
